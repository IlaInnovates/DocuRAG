"""
generator.py
------------
Given a user query and retrieved context chunks, generate a
grounded, cited answer using a Hugging Face text-generation model.

This is the 'G' (Generation) in RAG.

Two modes
---------
1. HuggingFace (default) — uses a local causal LM via the
   `transformers` library. Works fully offline after the first
   model download. Default: 'google/flan-t5-base' (250 MB, fast).

2. OpenAI (optional) — uses gpt-3.5-turbo via the `openai` package.
   Set OPENAI_API_KEY in your environment and pass mode='openai'.
"""

import os
import textwrap
from typing import List, Tuple

from document_loader import Chunk


# ── Prompt builder ────────────────────────────────────────────────────────────

def build_prompt(query: str, context_chunks: List[Tuple[Chunk, float]]) -> str:
    """
    Build the instruction prompt that the LLM will complete.

    Format
    ------
    Answer the question using ONLY the context provided below.
    If the answer is not in the context, say "I don't know."

    Context:
    [1] (source.pdf) chunk text ...
    [2] (source.pdf) chunk text ...

    Question: <query>
    Answer:
    """
    context_lines = []
    for i, (chunk, score) in enumerate(context_chunks, start=1):
        context_lines.append(
            f"[{i}] ({chunk.source}, similarity={score:.2f})\n{chunk.text}"
        )
    context_block = "\n\n".join(context_lines)

    prompt = (
        "Answer the question using ONLY the context provided below.\n"
        "If the answer cannot be found in the context, say \"I don't know.\"\n"
        "Keep the answer concise (2-4 sentences).\n\n"
        f"Context:\n{context_block}\n\n"
        f"Question: {query}\n"
        "Answer:"
    )
    return prompt


# ── HuggingFace generator ─────────────────────────────────────────────────────

class HFGenerator:
    """
    Wrapper around a Hugging Face text-generation pipeline.

    Default model: 'google/flan-t5-base'
      - Small (250 MB), instruction-tuned, works well for Q&A
      - No GPU needed for short answers
    """

    def __init__(self, model_name: str = "google/flan-t5-base"):
        from transformers import pipeline, AutoTokenizer, AutoModelForSeq2SeqLM

        print(f"Loading HF model '{model_name}' (first run downloads weights)...")
        self.model_name = model_name
        self.tokenizer  = AutoTokenizer.from_pretrained(model_name)
        self.model      = AutoModelForSeq2SeqLM.from_pretrained(model_name)
        self.pipe = pipeline(
            "text2text-generation",
            model     = self.model,
            tokenizer = self.tokenizer,
        )
        print("Model ready.")

    def generate(
        self,
        query          : str,
        context_chunks : List[Tuple[Chunk, float]],
        max_new_tokens : int = 200,
    ) -> str:
        prompt  = build_prompt(query, context_chunks)
        outputs = self.pipe(
            prompt,
            max_new_tokens = max_new_tokens,
            do_sample      = False,      # greedy for factual Q&A
        )
        return outputs[0]["generated_text"].strip()


# ── OpenAI generator (optional) ───────────────────────────────────────────────

class OpenAIGenerator:
    """
    Uses gpt-3.5-turbo (or gpt-4) via the openai package.
    Requires: pip install openai && export OPENAI_API_KEY=sk-...
    """

    def __init__(self, model: str = "gpt-3.5-turbo"):
        try:
            import openai
        except ImportError:
            raise ImportError("Install openai: pip install openai")
        self.client = openai.OpenAI(api_key=os.environ["OPENAI_API_KEY"])
        self.model  = model

    def generate(
        self,
        query          : str,
        context_chunks : List[Tuple[Chunk, float]],
        max_new_tokens : int = 300,
    ) -> str:
        prompt = build_prompt(query, context_chunks)
        resp   = self.client.chat.completions.create(
            model      = self.model,
            messages   = [{"role": "user", "content": prompt}],
            max_tokens = max_new_tokens,
            temperature= 0.0,
        )
        return resp.choices[0].message.content.strip()


# ── Factory ───────────────────────────────────────────────────────────────────

def get_generator(mode: str = "hf", **kwargs):
    """
    mode='hf'     → HFGenerator (default, free, offline)
    mode='openai' → OpenAIGenerator (requires API key)
    """
    if mode == "openai":
        return OpenAIGenerator(**kwargs)
    return HFGenerator(**kwargs)


